# Clave secreta de Stripe (obtén una en https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_tu_clave_secreta_aqui

# URL pública del backend para redirecciones de Stripe Checkout
BACKEND_PUBLIC_URL=https://academia-backend-s9np.onrender.com

# Secreto para verificar webhooks (opcional, si añades webhooks de Stripe)
# STRIPE_WEBHOOK_SECRET=whsec_tu_webhook_secret_aqui

# SMTP2GO para envío de emails (asesoría de inmigración)
SMTP2GO_USERNAME=tu_usuario_smtp2go
SMTP2GO_PASSWORD=tu_password_smtp2go
# Remitente VERIFICADO en SMTP2GO (Sending > Verified Senders) — obligatorio
SMTP2GO_FROM=tu_email_verificado@ejemplo.com
# Opcional: buzón donde recibir avisos (concurso, asesoría, etc.)
# SMTP2GO_TO=admin@academiadeinmigrantes.es

# Configuración del servidor
PORT=10000
NODE_ENV=production

# Precio de formación profesional (en euros)
FORMACION_PRICE_EUR=10

# Configuración de CORS (opcional)
# ALLOWED_ORIGINS=http://localhost:3000,https://tu-frontend.com

# Configuración de logs (opcional)
# LOG_LEVEL=info
# LOG_FILE=app.log
